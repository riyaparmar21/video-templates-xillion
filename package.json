{
  "name": "video-templates",
  "version": "1.0.0",
  "description": "Remotion video editing templates with MCP server integration",
  "type": "module",
  "scripts": {
    "assets:map": "node scripts/build-asset-map.cjs",
    "postinstall": "node scripts/verify-native-deps.cjs",
    "prestart": "node scripts/build-asset-map.cjs",
    "prebuild": "node scripts/build-asset-map.cjs",
    "prerender": "node scripts/build-asset-map.cjs",
    "prerender:cli": "node scripts/build-asset-map.cjs",
    "start": "remotion studio",
    "build": "remotion bundle",
    "render": "node scripts/render-video.mjs",
    "render:cli": "remotion render",
    "render:all": "node scripts/render-all-templates.mjs",
    "svg:generate": "python3 scripts/generate-svg-library.py",
    "svg:validate": "python3 scripts/validate-svg-remotion.py",
    "svg:optimize": "svgo -f assets/svg -r --config svgo.config.cjs",
    "svg:manifest": "python3 scripts/build-manifest.py",
    "svg:pipeline": "bash scripts/pipeline.sh",
    "svg:pipeline:all": "bash scripts/pipeline.sh --all",
    "assets:fetch": "python3 scripts/fetch-assets.py",
    "assets:fetch:backgrounds": "python3 scripts/fetch-assets.py --preset backgrounds",
    "assets:fetch:overlays": "python3 scripts/fetch-assets.py --preset overlays",
    "assets:fetch:all": "python3 scripts/fetch-assets.py --preset all",
    "assets:fetch:dry-run": "python3 scripts/fetch-assets.py --preset all --dry-run",
    "assets:presets": "python3 scripts/fetch-assets.py --list-presets",
    "assets:redownload": "python3 scripts/redownload-from-metadata.py",
    "text:search-bar": "node scripts/set-text.mjs search-bar",
    "text:notification": "node scripts/set-text.mjs notification",
    "text:inflate": "node scripts/set-text.mjs inflate",
    "text:progress-bar": "node scripts/set-text.mjs progress-bar",
    "text:blur-scroller": "node scripts/set-text.mjs blur-scroller",
    "text:vault-cards": "node scripts/set-text.mjs vault-cards",
    "text:tweet": "node scripts/set-text.mjs tweet",
    "text:product-reveal": "node scripts/set-text.mjs product-reveal",
    "text:social-handle": "node scripts/set-text.mjs social-handle",
    "text:showreel-grid": "node scripts/set-text.mjs showreel-grid",
    "text:showreel-frames": "node scripts/set-text.mjs showreel-frames",
    "text:stack-hiring": "node scripts/set-text.mjs stack-hiring",
    "text:slideshow": "node scripts/set-text.mjs slideshow",
    "text:design-preview": "node scripts/set-text.mjs design-preview",
    "text:gen-ai-features": "node scripts/set-text.mjs gen-ai-features",
    "text:vault-card-features": "node scripts/set-text.mjs vault-card-features",
    "text:showcase": "node scripts/set-text.mjs showcase",
    "text:route-text": "node scripts/set-text.mjs route-text",
    "text:web-screens": "node scripts/set-text.mjs web-screens",
    "text:help": "node scripts/set-text.mjs",
    "ground:plan": "python3 scripts/ground-captions-plan.py",
    "ground:plan:help": "python3 scripts/ground-captions-plan.py --help",
    "ground:tuner": "python3 scripts/ground-tuner-server.py",
    "screens": "node scripts/set-screens.mjs",
    "screens:help": "node scripts/set-screens.mjs",
    "aspect": "node scripts/set-aspect.mjs",
    "aspect:help": "node scripts/set-aspect.mjs",
    "paths:inflate": "node scripts/generate-letter-paths.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.438",
    "@remotion/cli": "4.0.438",
    "@remotion/compositor-darwin-arm64": "4.0.438",
    "@remotion/google-fonts": "4.0.438",
    "@remotion/mcp": "4.0.438",
    "@remotion/player": "4.0.438",
    "@remotion/renderer": "4.0.438",
    "flubber": "^0.4.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "4.0.438",
    "zod": "^3.22.3"
  },
  "devDependencies": {
    "@types/flubber": "^0.4.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "opentype.js": "^1.3.4",
    "playwright": "^1.58.2",
    "svgo": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
