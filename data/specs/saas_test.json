{
  "palette": {
    "primary": "#FFD700",
    "secondary": "#1E90FF",
    "background": "#0A0A0A",
    "text": "#FFFFFF",
    "accent": "#FF6B35"
  },
  "typography": {
    "heading": "Montserrat",
    "body": "Inter",
    "mono": "JetBrains Mono"
  },
  "duration": 25,
  "fps": 30,
  "width": 1080,
  "height": 1920,
  "audio": {
    "src": "",
    "reactive": false
  },
  "camera": {
    "kenBurns": true,
    "kenBurnsScale": 1.06,
    "punchZoom": true,
    "punchInterval": 4,
    "punchScale": 1.025
  },
  "scenes": [
    {
      "template": "KineticCaptions",
      "duration": 6,
      "params": {
        "groups": [
          {
            "lines": [
              {
                "words": [
                  {
                    "text": "Meet",
                    "style": "big-blue"
                  },
                  {
                    "text": "Flowboard",
                    "style": "big-blue"
                  }
                ]
              }
            ]
          },
          {
            "lines": [
              {
                "words": [
                  {
                    "text": "the",
                    "style": "filler"
                  },
                  {
                    "text": "project",
                    "style": "normal"
                  },
                  {
                    "text": "management",
                    "style": "normal"
                  },
                  {
                    "text": "tool",
                    "style": "normal"
                  }
                ]
              }
            ]
          },
          {
            "lines": [
              {
                "words": [
                  {
                    "text": "your",
                    "style": "filler"
                  },
                  {
                    "text": "team",
                    "style": "emphasis-gold"
                  },
                  {
                    "text": "actually",
                    "style": "emphasis-gold"
                  },
                  {
                    "text": "wants",
                    "style": "emphasis-gold"
                  },
                  {
                    "text": "to",
                    "style": "filler"
                  },
                  {
                    "text": "use",
                    "style": "emphasis-blue"
                  }
                ]
              }
            ]
          }
        ]
      },
      "transition": "wipe_left",
      "transitionDuration": 0.5
    },
    {
      "template": "GlassPanel",
      "duration": 5,
      "params": {
        "title": "Drag. Drop. Done.",
        "body": "Flowboard turns chaotic workflows into visual pipelines in seconds.",
        "style": "bordered",
        "accentColor": "#FFD700"
      },
      "transition": "crossfade",
      "transitionDuration": 0.5
    },
    {
      "template": "ThreeDCardFlip",
      "duration": 3,
      "params": {
        "image": "assets/saas_test/kanban.webp",
        "headline": "Visual Pipelines",
        "style": "tilt",
        "cardWidthPercent": 65,
        "reflection": true,
        "particles": true,
        "bgColor": "#0A0A0A"
      },
      "transition": "slide_up",
      "transitionDuration": 0.5
    },
    {
      "template": "ParallaxImageReveal",
      "duration": 3,
      "params": {
        "image": "assets/saas_test/dashboard.png",
        "headline": "Built for Speed",
        "subtitle": "Real-time dashboards your team will love",
        "speed": "slow",
        "revealStyle": "iris",
        "scrimOpacity": 0.7,
        "bgColor": "#0A0A0A"
      },
      "transition": "wipe_left",
      "transitionDuration": 0.5
    },
    {
      "template": "NumberCounterScene",
      "duration": 4,
      "params": {
        "target": 12000,
        "prefix": "",
        "suffix": "+",
        "label": "Teams Trust Flowboard Worldwide",
        "fontSize": 200,
        "color": "#FFD700",
        "glowColor": "#FFD700",
        "bgColor": "#0A0A0A"
      },
      "transition": "zoom_in",
      "transitionDuration": 0.5
    },
    {
      "template": "ListReveal",
      "duration": 8,
      "params": {
        "title": "Why Teams Switch to Flowboard",
        "items": [
          "94% report faster delivery within the first month of switching",
          "Visual pipelines replace chaotic spreadsheets and email chains",
          "Drag-and-drop simplicity means zero learning curve for your team",
          "Real-time dashboards keep everyone aligned and on track"
        ],
        "style": "checkmarks",
        "staggerDelay": 35,
        "itemColor": "#1E90FF"
      },
      "transition": "crossfade",
      "transitionDuration": 0.5
    },
    {
      "template": "TextRevealWipe",
      "duration": 4,
      "params": {
        "headline": "Try Flowboard Free",
        "subtitle": "30 days. No credit card.",
        "wipeDirection": "center",
        "wipeColor": "#FFD700",
        "headlineSize": 72,
        "subtitleSize": 42
      },
      "transition": "crossfade",
      "transitionDuration": 0.5
    },
    {
      "template": "LogoStinger",
      "duration": 3,
      "params": {
        "logo": "assets/saas_test/logo.jpeg",
        "tagline": "Project management reimagined",
        "style": "particles",
        "logoSize": 280
      },
      "transition": "crossfade",
      "transitionDuration": 0
    }
  ]
}