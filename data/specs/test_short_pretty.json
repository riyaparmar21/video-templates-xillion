{
  "palette": {
    "primary": "#FFD700",
    "secondary": "#1E90FF",
    "background": "#0A0A0A",
    "text": "#FFFFFF",
    "accent": "#FF6B35"
  },
  "typography": {
    "heading": "Montserrat",
    "body": "Inter",
    "mono": "JetBrains Mono"
  },
  "duration": 20,
  "fps": 30,
  "width": 1080,
  "height": 1920,
  "audio": {
    "src": "",
    "reactive": false
  },
  "camera": {
    "kenBurns": true,
    "kenBurnsScale": 1.06,
    "punchZoom": true,
    "punchInterval": 4,
    "punchScale": 1.025
  },
  "scenes": [
    {
      "template": "KineticCaptions",
      "duration": 4,
      "params": {
        "groups": [
          {
            "lines": [
              {
                "text": "73%",
                "style": "emphasis-gold big"
              }
            ]
          },
          {
            "lines": [
              {
                "text": "of consumers",
                "style": "normal"
              }
            ]
          },
          {
            "lines": [
              {
                "text": "prefer brands",
                "style": "filler"
              }
            ]
          },
          {
            "lines": [
              {
                "text": "that personalize",
                "style": "accent-blue"
              }
            ]
          },
          {
            "lines": [
              {
                "text": "their experience",
                "style": "normal"
              }
            ]
          }
        ]
      },
      "transition": "crossfade",
      "transitionDuration": 0.5
    },
    {
      "template": "NumberCounterScene",
      "duration": 3,
      "params": {
        "target": 40,
        "prefix": "",
        "suffix": "% increase in revenue",
        "label": "AI-driven personalization",
        "particleCount": 15,
        "glowColor": "#FFD700"
      },
      "transition": "zoom_in",
      "transitionDuration": 0.5
    },
    {
      "template": "BlurTextScroller",
      "duration": 6,
      "params": {
        "words": [
          "Real-time data collection for actionable insights",
          "Machine learning models that adapt to user preferences",
          "Seamless integration across all platforms"
        ],
        "fontSize": 42,
        "textColor": "#FFFFFF",
        "bgColor": "#0A0A0A"
      },
      "transition": "slide_up",
      "transitionDuration": 0.5
    },
    {
      "template": "TextRevealWipe",
      "duration": 7,
      "params": {
        "headline": "Visit personalize.ai",
        "subtitle": "Start optimizing with AI today",
        "wipeDirection": "center",
        "wipeColor": "#FFD700",
        "headlineSize": 48,
        "subtitleSize": 32
      },
      "transition": "wipe_left",
      "transitionDuration": 0.5
    }
  ]
}